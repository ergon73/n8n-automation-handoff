      "name": "AI Request"
    },
    {
      "parameters": {
        "jsCode": "const src = $input.first().json;\n\nconst text = src.output?.[0]?.content?.[0]?.text;\n\nif (!text) {\n  throw new Error('AI response text not found');\n}\n\nconst parsed = JSON.parse(text);\n\nreturn [\n  {\n    json: {\n      price: Number(parsed.price),\n      offer: String(parsed.offer),\n    },\n  },\n];\n"
      },
