# n8n environment example for the demo workflow.
# Copy values into your n8n deployment environment. Do not commit real values.

NPR10_ENVIRONMENT=test
NPR10_TELEGRAM_CHAT_ID_TEST=REPLACE_WITH_TELEGRAM_CHAT_ID

BPIUM_BASE_URL_TEST=https://your-workspace.bpium.ru
BPIUM_CATALOG_ID_TEST=17
BPIUM_SESSION_COOKIE_TEST=connect.sid=REPLACE_WITH_BPIUM_SESSION_COOKIE

YOO_KASSA_RETURN_URL=https://example.com/payment-return

# Required only if your n8n instance intentionally allows expressions to read env vars.
# Keep this setting aligned with your security model.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false
